# Kanboard JSON-RPC endpoint (base URL or full /jsonrpc.php)
KANBOARD_URL=http://127.0.0.1/kanboard
KANBOARD_API_USER=jsonrpc
KANBOARD_API_TOKEN=replace_with_api_token

# Shared queue SQLite database (must match plugin side)
QUEUE_DB_PATH=/var/www/kanboard/data/autopdf_queue.sqlite
SCHEMA_PATH=/opt/autopdf/schema.sql

# Existing converter script path (current exel2pdf.py)
CONVERTER_SCRIPT_PATH=/opt/autopdf/exel2pdf.py
PYTHON_BIN=python3

# Optional explicit binary path for LibreOffice (used for .doc fallback)
# LIBREOFFICE_BIN=/usr/bin/soffice

# Worker behavior
HTTP_TIMEOUT_SEC=30
POLL_INTERVAL_SEC=2
MAX_RETRIES=5
TEMP_DIR=/tmp/autopdf

# Logging
LOG_FILE=/var/log/autopdf-worker.log
LOG_LEVEL=INFO
