# HTTP bind
BOT_SERVICE_HOST=0.0.0.0
BOT_SERVICE_PORT=8089
BOT_SERVICE_ENDPOINT=/events/assignee-changed

# Shared secret for X-Webhook-Token header
BOT_SERVICE_SHARED_SECRET=replace_with_shared_secret

# Telegram
BOT_SERVICE_TELEGRAM_BOT_TOKEN=replace_with_bot_token
BOT_SERVICE_TELEGRAM_API_BASE=https://api.telegram.org
BOT_SERVICE_MESSAGE_TEXT=You have a new task assigned. Open Kanboard.

# SQLite storage
BOT_SERVICE_DB_PATH=/var/www/kanboard/data/kanboard_bot_service.sqlite
BOT_SERVICE_SCHEMA_PATH=/opt/autopdf/worker/bot_service/schema.sql

# Runtime
BOT_SERVICE_HTTP_TIMEOUT_SEC=15
BOT_SERVICE_MAX_BODY_BYTES=32768

# Logging
BOT_SERVICE_LOG_FILE=/var/log/kanboard-bot-service.log
BOT_SERVICE_LOG_LEVEL=INFO
